# Environment
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://eipsyc5_user:dev_password_123@localhost:5432/eipsyc5_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# APIs
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Commission Rates
COMMISSION_HOTEL_PERCENT=10
COMMISSION_OPERATOR_PERCENT=15
COMMISSION_ACCOMMODATION_PERCENT=15
COMMISSION_ACTIVITY_PERCENT=5

# Owner Payout (SECURE BACKEND ONLY - NEVER IN FRONTEND)
EIPSYC5_OWNER_PAYOUT_ACCOUNT=PLACEHOLDER_SECURE_BACKEND_ONLY
